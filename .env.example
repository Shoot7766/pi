# --- Central AI Boss Environment Configuration ---

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Comma-separated Telegram User IDs allowed to access the system (e.g. 123456789,987654321)
ADMIN_IDS=123456789

# LLM Provider Keys (CrewAI & Brain Engine)
# Set according to your preferred LLM backend
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Local Storage Database Paths
DATABASE_URL=sqlite:///d:/ai_robot/pi/storage/db.sqlite3
CHROMADB_DIR=d:/ai_robot/pi/storage/chroma

# FastAPI Server Host & Port
FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=8000

# Security and Safety Controls
# PyAutoGUI Failsafe (Move mouse to any corner of the screen to halt operations)
GUI_FAILSAFE=True
# Command whitelist strictness (True = only run predefined safe commands, False = analyze dynamically)
STRICT_COMMAND_WHITELIST=True
